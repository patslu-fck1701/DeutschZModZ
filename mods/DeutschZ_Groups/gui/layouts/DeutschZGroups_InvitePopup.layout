FrameWidgetClass DZG_InvitePopupRoot {
 visible 1
 color 0 0 0 0
 position 0 0
 size 1 1
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass DZG_PopupBg {
   color 0.03 0.03 0.03 0.97
   position 0 0
   size 420 230
   halign center_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style editor_quad
   {
    TextWidgetClass DZG_PopupTitle {
     ignorepointer 1
     position 20 18
     size 380 28
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "DeutschZ Einladung"
     font "gui/fonts/sdf_MetronLight20"
    }
    TextWidgetClass DZG_PopupText {
     ignorepointer 1
     position 20 62
     size 380 82
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "Du wurdest in eine Gruppe eingeladen."
     font "gui/fonts/sdf_MetronLight14"
     "text valign" top
    }
    ButtonWidgetClass DZG_AcceptInviteButton {
     position 20 168
     size 180 36
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "Annehmen"
     font "gui/fonts/sdf_MetronLight16"
     color 0.05 0.20 0.05 1
    }
    ButtonWidgetClass DZG_DeclineInviteButton {
     position 220 168
     size 180 36
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "Ablehnen"
     font "gui/fonts/sdf_MetronLight16"
     color 0.25 0.03 0.03 1
    }
   }
  }
 }
}
