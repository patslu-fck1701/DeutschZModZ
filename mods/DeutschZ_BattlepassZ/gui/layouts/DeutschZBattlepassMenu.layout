FrameWidgetClass DZBP_Root {
 position 0 0
 size 1 1
 color 0 0 0 120
 {
  WindowWidgetClass DZBP_Window {
   position 0.18 0.12
   size 0.64 0.76
   color 20 20 20 235
   {
    TextWidgetClass DZBP_Title {
     position 0.02 0.02
     size 0.70 0.05
     text "DeutschZ BattlepassZ"
     font "gui/fonts/sdf_MetronBook24"
     color 220 30 30 255
    }
    ButtonWidgetClass DZBP_Close {
     position 0.91 0.02
     size 0.07 0.05
     text "X"
    }
    TextWidgetClass DZBP_Progress {
     position 0.02 0.09
     size 0.94 0.045
     text "Level 1 | XP 0"
     font "gui/fonts/sdf_MetronBook18"
     color 230 230 230 255
    }
    TextWidgetClass DZBP_Status {
     position 0.02 0.145
     size 0.94 0.04
     text "O = open | CTRL+O = sync | CTRL+B = claim first available"
     font "gui/fonts/sdf_MetronBook14"
     color 180 180 180 255
    }
    TextWidgetClass DZBP_FreeHeader {
     position 0.02 0.205
     size 0.45 0.04
     text "FREE REWARDS"
     font "gui/fonts/sdf_MetronBook18"
     color 255 255 255 255
    }
    TextWidgetClass DZBP_PremiumHeader {
     position 0.52 0.205
     size 0.45 0.04
     text "PREMIUM REWARDS"
     font "gui/fonts/sdf_MetronBook18"
     color 220 30 30 255
    }
    TextListboxWidgetClass DZBP_FreeList {
     position 0.02 0.26
     size 0.45 0.50
    }
    TextListboxWidgetClass DZBP_PremiumList {
     position 0.52 0.26
     size 0.45 0.50
    }
    ButtonWidgetClass DZBP_ClaimFree {
     position 0.02 0.79
     size 0.20 0.055
     text "Claim Free"
    }
    ButtonWidgetClass DZBP_ClaimPremium {
     position 0.52 0.79
     size 0.20 0.055
     text "Claim Premium"
    }
    ButtonWidgetClass DZBP_Sync {
     position 0.78 0.79
     size 0.19 0.055
     text "Sync"
    }
   }
  }
 }
}
