     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "Signalstation aktiv"
     font "gui/fonts/sdf_MetronLight14"
     "text halign" center
     "text valign" center
    }
    ProgressBarWidgetClass Progress {
     disabled 0
     ignorepointer 1
     color 0.0 1.0 0.08 1
