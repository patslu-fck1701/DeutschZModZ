FrameWidgetClass rootFrame {
 color 1 1 1 1
 position 0.006 0.235
 size 440 122
 halign right_ref
 valign bottom_ref
 hexactpos 0
 vexactpos 0
 hexactsize 1
 vexactsize 1
 {
  PanelWidgetClass BgFrame {
